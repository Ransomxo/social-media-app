{
  "build": {
    "builder": "@railway/nixpacks",
    "buildCommand": "cd ../.. && pnpm install && cd packages/backend && pnpm install && pnpm build"
  },
  "deploy": {
    "startCommand": "pnpm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "watchPatterns": [
    "packages/backend/**/*"
  ]
}
