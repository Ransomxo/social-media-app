{
  "version": 2,
  "buildCommand": "DEBUG=* cd ../.. && pnpm install && cd packages/backend && DEBUG=* pnpm prisma generate && DEBUG=* tsc",
  "installCommand": "cd ../.. && pnpm install",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["prisma/**/*", "dist/**/*", ".env*"],
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.js"
    }
  ],
  "env": {
    "DATABASE_URL": "@database-url",
    "JWT_SECRET": "@jwt-secret",
    "NEXT_PUBLIC_APP_URL": "@next-public-app-url",
    "DEBUG": "*"
  }
}
