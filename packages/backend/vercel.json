{
  "version": 2,
  "buildCommand": "cd ../.. && pnpm install && cd packages/backend && pnpm build",
  "installCommand": "cd ../.. && pnpm install",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.js"
    }
  ],
  "env": {
    "DATABASE_URL": "@database-url",
    "JWT_SECRET": "@jwt-secret",
    "NEXT_PUBLIC_APP_URL": "@next-public-app-url"
  }
}
