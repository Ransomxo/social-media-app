// Test schema with same structure but different database URL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("TEST_DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  plan        String   @default("minimal")
  teamMembers String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
